+    /// Exp3-IX: sample a move index from the mixed strategy.
+    /// Returns (sampling_probability_of_chosen, chosen_index).
+    /// NO heap allocations — single O(K) pass with cumulative sampling.
+    #[inline]
+    fn exp3_sample(side_map: &[MoveNode]) -> (f32, usize) {
+        let k = side_map.len();
+        debug_assert!(k > 0);
+        if k == 1 {
+            return (1.0, 0);
+        }
+
+        // Total weight sum — needed to normalize
+        let total_w: f32 = side_map.iter().map(|n| n.exp3_w).sum();
+        let total_w_inv = 1.0 / total_w;
+        let gamma_k = EXP3_GAMMA / k as f32;
+        let one_minus_gamma = 1.0 - EXP3_GAMMA;
+
+        // Sample via single cumulative pass (no allocation)
+        let r: f32 = rng().random::<f32>();
+        let mut cumsum = 0.0f32;
+        let mut chosen = k - 1; // fallback
+        let mut chosen_p = 0.0f32;
+
+        for (i, node) in side_map.iter().enumerate() {
+            let p_i = one_minus_gamma * (node.exp3_w * total_w_inv) + gamma_k;
