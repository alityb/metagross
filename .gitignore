/.venv*/
/.claude/
/.opencode/
/.ruff_cache/
/.pytest_cache/
/.ladder_credentials
/.ladder_exit_password
/.ladder_exit_r1_credentials
/.ladder_r2_credentials

__pycache__/
target/
*.log
*.out
*.pid

# Local production artifacts. Their required hashes are in
# results/accepted-r1/artifacts.json.
/srcs/models/
/srcs/runtime/*
!/srcs/runtime/.gitkeep
/srcs/vendor/foul-play/
/srcs/vendor/metamon/

# Historical local dependencies and generated research payloads. Files already
# tracked in the archive remain tracked; these rules prevent new run artifacts
# from being added accidentally.
/experimental/external/
/experimental/data/**
/experimental/runs/**
!/experimental/runs/README.md
!/experimental/runs/iteration_log.md
/experimental/src/external/
/experimental/src/nets/checkpoints/**
/experimental/engine/**/linux_wheels/
/experimental/engine/**/docs/make.bat
